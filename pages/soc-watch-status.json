  "schema_version": 1,
  "name": "Watch Status",
  "slug": "soc-watch-status",
  "description": "Queue + active state detail.",
  "tags": [
    "socmetric"
  ],
  "components": [
    {
      "id": "099fb995346f31c7",
      "type": "markdown",
      "title": null,
      "body": "**SOCMetric** \u00b7 Last sync: `<<RESOURCE.soc_settings.last_sync_completed_at | relative_time>>` \u00b7 Status: `<<RESOURCE.soc_settings.last_sync_status>>`"
    },
    {
      "id": "d72e5ee9b3678339",
      "type": "markdown",
      "title": null,
      "body": "| [Home](/pages/soc-dashboard-home) | [Calendar](/pages/soc-calendar) | [Watch Status](/pages/soc-watch-status) | [Flow](/pages/soc-flow) | [Response Speed](/pages/soc-response-speed) | [Capacity](/pages/soc-capacity) | [Patterns](/pages/soc-patterns) | [Projections](/pages/soc-projections) | [Context Ledger](/pages/soc-context-ledger) | [Setup](/pages/soc-setup) |\n| --- | --- | --- | --- | --- | --- | --- | --- | --- | --- |\n"
    },
    {
      "id": "63d721d24d2dde77",
      "type": "markdown",
      "title": null,
      "visibility_formula": "<<RESOURCE.soc_settings.first_sync_completed_at == null>>",
      "body": "> Setup is incomplete. Open the [Setup page](/pages/soc-setup) to configure the project, classify statuses, and run the first sync."
    },
    {
      "id": "a95dcb8aebb202ef",
      "type": "table",
      "title": "Open tickets",
      "rows_formula": "<<FILTER(RESOURCE.soc_tickets_cache.tickets, t -> t.resolved_at == null) | sort(created_at desc) | take(500)>>",
      "columns": [
        {
          "field": "key",
          "header": "Key",
          "link_formula": "https://<<RESOURCE.soc_settings.jira_domain>>/browse/<<row.key>>"
        },
        {
          "field": "summary",
          "header": "Summary"
        },
        {
          "field": "status_name",
          "header": "Status"
        },
        {
          "field": "assignee",
          "header": "Assignee"
        },
        {
          "field": "age_hours",
          "header": "Age (h)",
          "value_formula": "<<DATE_DIFF(NOW(), row.created_at, 'hours') | round(1)>>"
        }
      ]
    },
    {
      "id": "62d7d5184b7a313d",
      "type": "bar_chart",
      "title": "Aging buckets",
      "data_formula": "<<RESOURCE.soc_metrics_cache.flow.aging_buckets>>",
      "x_field": "label",
      "y_field": "count"
    }
  ],
  "access": "tenant",
  "exported_at": "2026-04-21T00:00:00Z"
}