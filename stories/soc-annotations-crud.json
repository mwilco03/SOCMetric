      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "op": "<<webhook.body.op>>",
          "current": "<<RESOURCE.soc_day_annotations>>",
          "next_value": "=IF(webhook.body.op = 'set', MERGE(RESOURCE.soc_day_annotations, OBJECT(webhook.body.key, webhook.body.value)), IF(webhook.body.op = 'delete', OMIT(RESOURCE.soc_day_annotations, webhook.body.key), IF(webhook.body.op = 'bulk_set', MERGE(RESOURCE.soc_day_annotations, webhook.body.mappings), RESOURCE.soc_day_annotations)))"
        }
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
