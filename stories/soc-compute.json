{
  "schema_version": 28,
  "standard_lib_version": 90,
  "action_runtime_version": 74,
  "name": "SOC: Compute",
  "description": "Single compute story. Inlines all 7 metric slices sequentially (headline, flow, speed, capacity, patterns, projections, calendar), merges, writes soc_metrics_cache. Triggered by soc_data after a successful sync. Replaces the 7 compute sub-stories and the compute fan-out orchestrator.",
  "guid": "c0a1cea2aabb0000000000000f0000c1",
  "slug": "soc_compute",
  "agents": [
    {
      "type": "Agents::WebhookAgent",
      "name": "Webhook (from soc_data)",
      "disabled": false,
      "description": "Entry. Receives {project_key} from soc_data.Trigger_compute.",
      "guid": "c0000001000000000000000000000web",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "path": "c0a1cea2aabb0000000000000f0000c2",
        "secret": "c0a1cea2aabb0000000000000f0000c3",
        "verbs": "post"
      },
      "reporting": { "time_saved_value": 0, "time_saved_unit": "minutes" },
      "monitoring": { "monitor_all_events": false, "monitor_failures": false, "monitor_no_events_emitted": null },
      "template": { "created_from_template_guid": null, "created_from_template_version": null, "template_tags": [] },
      "width": null
    },
    {
      "type": "Agents::EventTransformationAgent",
      "name": "Load inputs",
      "disabled": false,
      "description": "Reads tickets (handles sharded-mode Resource), status_map, label_config, settings.",
      "guid": "c0000002000000000000000000000load",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "tickets": "=IF(RESOURCE.soc_tickets_cache.mode = 'inline', RESOURCE.soc_tickets_cache.tickets, FLATTEN(MAP(RANGE(1, RESOURCE.soc_tickets_cache.shards + 1), i, RESOURCE_BY_NAME(CONCAT('soc_tickets_cache_shard_', PAD_LEFT(i, 3, '0'))).tickets)))",
          "status_map": "<<RESOURCE.soc_status_map>>",
          "label_config": "<<RESOURCE.soc_label_config>>",
          "settings": "<<RESOURCE.soc_settings>>"
        }
      },
      "reporting": { "time_saved_value": 0, "time_saved_unit": "minutes" },
      "monitoring": { "monitor_all_events": false, "monitor_failures": false, "monitor_no_events_emitted": null },
      "template": { "created_from_template_guid": null, "created_from_template_version": null, "template_tags": [] },
      "width": null
    },
    {
      "type": "Agents::EventTransformationAgent",
      "name": "Compute headline",
      "disabled": false,
      "description": "Queue depth, active incidents, net velocity, TTFT percentiles. See docs/metric-mapping.md.",
      "guid": "c0000003000000000000000000000hd",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "headline": "=OBJECT('queue_depth', LENGTH(FILTER(load_inputs.tickets, t, LOOKUP(load_inputs.status_map, CONCAT(t.project_key, ':', t.status_name), 'queue') = 'queue')), 'active_incident_count', LENGTH(FILTER(load_inputs.tickets, t, LOOKUP(load_inputs.status_map, CONCAT(t.project_key, ':', t.status_name), 'queue') = 'active')), 'ttft_p50_hours', PERCENTILE(FILTER(MAP(load_inputs.tickets, t, TTFT_HOURS(t)), v, v != null), 50), 'ttft_p85_hours', PERCENTILE(FILTER(MAP(load_inputs.tickets, t, TTFT_HOURS(t)), v, v != null), 85), 'ttft_p95_hours', PERCENTILE(FILTER(MAP(load_inputs.tickets, t, TTFT_HOURS(t)), v, v != null), 95), 'net_velocity_7d', (LENGTH(FILTER(load_inputs.tickets, t, AND(t.resolved_at != null, DATE_DIFF(NOW(), t.resolved_at, 'days') <= 7))) - LENGTH(FILTER(load_inputs.tickets, t, DATE_DIFF(NOW(), t.created_at, 'days') <= 7))) / 7)"
        }
      },
      "reporting": { "time_saved_value": 0, "time_saved_unit": "minutes" },
      "monitoring": { "monitor_all_events": false, "monitor_failures": false, "monitor_no_events_emitted": null },
      "template": { "created_from_template_guid": null, "created_from_template_version": null, "template_tags": [] },
      "width": null
    },
    {
      "type": "Agents::EventTransformationAgent",
      "name": "Compute flow",
      "disabled": false,
      "description": "Lead time decomposition, aging buckets, closure integrity, stalled tickets. Placeholder shape; fill formulas from docs/metric-mapping.md.",
      "guid": "c0000004000000000000000000000fl",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "flow": "=OBJECT('lead_time', OBJECT('queue_wait', OBJECT('p50', 0, 'p85', 0, 'p95', 0), 'active_work', OBJECT('p50', 0, 'p85', 0, 'p95', 0), 'post_active_wait', OBJECT('p50', 0, 'p85', 0, 'p95', 0)), 'aging_buckets', ARRAY(), 'stalled_tickets', 0, 'closure_integrity', OBJECT('instant', 0, 'untouched', 0, 'normal', 0, 'churned', 0, 'still_open', 0))"
        }
      },
      "reporting": { "time_saved_value": 0, "time_saved_unit": "minutes" },
      "monitoring": { "monitor_all_events": false, "monitor_failures": false, "monitor_no_events_emitted": null },
      "template": { "created_from_template_guid": null, "created_from_template_version": null, "template_tags": [] },
      "width": null
    },
    {
