      "description": "Response time trend and closure bursts. Placeholder shape.",
      "guid": "c0000005000000000000000000000sp",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "speed": "=OBJECT('ttft_percentiles', OBJECT('p50', null, 'p85', null, 'p95', null), 'response_time_trend', ARRAY(), 'closure_bursts', ARRAY())"
        }
      },
      "reporting": { "time_saved_value": 0, "time_saved_unit": "minutes" },
      "monitoring": { "monitor_all_events": false, "monitor_failures": false, "monitor_no_events_emitted": null },
