      "description": null,
      "guid": "84cb7c03b69eeb93a58db97d1a44db29",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "mode": "message_only",
        "payload": {
          "op": "<<op>>",
          "current": "<<RESOURCE.soc_status_map>>",
          "next_value": "<<CASE(true, op == 'set', MERGE(RESOURCE.soc_status_map, { (key): value }), op == 'delete', OMIT(RESOURCE.soc_status_map, key), op == 'bulk_set', MERGE(RESOURCE.soc_status_map, mappings), RESOURCE.soc_status_map)>>"
        }
      },
