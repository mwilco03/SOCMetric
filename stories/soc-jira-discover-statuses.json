        "payload": {
          "discovered": "<<MAP_LAMBDA(FLATTEN(MAP_LAMBDA(.body, t, t.statuses)), s, {\"status_name\": s.name, \"category_key\": s.statusCategory.key, \"suggested_classification\": CASE(true, s.statusCategory.key == 'new', 'queue', s.statusCategory.key == 'indeterminate', 'active', s.statusCategory.key == 'done', 'done', true, 'queue'), \"confidence\": CASE(true, s.statusCategory.key == 'new' OR s.statusCategory.key == 'done', 'high', true, 'medium'), \"reason\": 'Derived from Jira statusCategory.key.'})>>"
        }
