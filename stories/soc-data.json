      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "project_key": "<<RESOURCE.soc_settings.project_key>>",
          "domain": "<<RESOURCE.soc_settings.jira_domain>>",
          "date_range_days": "<<RESOURCE.soc_settings.date_range_days>>",
          "max_issues": "<<RESOURCE.soc_settings.max_issues_per_sync>>",
          "page_size": "<<RESOURCE.soc_settings.page_size>>",
          "start_date": "=DATE_FORMAT(DATE_SUBTRACT(NOW(), RESOURCE.soc_settings.date_range_days, 'days'), 'yyyy-MM-dd')",
          "now": "=NOW()"
        }
      },
      "reporting": { "time_saved_value": 0, "time_saved_unit": "minutes" },
