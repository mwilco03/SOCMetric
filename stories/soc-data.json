      "guid": "a000005000000000000000000000gt01",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "rules": [ { "type": "formula", "value": "true", "path": "=LENGTH(sync_entry.project_key) > 0" } ]
      },
