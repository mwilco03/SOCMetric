      "disabled": false,
      "description": "Returns {discovered: [{status_name, category_key, suggested_classification, confidence, reason}]}.",
      "guid": "a00001200000000000000000000et04",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "discovered": "=MAP(FLATTEN(MAP(fetch_project_statuses.body, t, t.statuses)), s, OBJECT('status_name', s.name, 'category_key', s.statusCategory.key, 'suggested_classification', IF(s.statusCategory.key = 'new', 'queue', IF(s.statusCategory.key = 'indeterminate', 'active', IF(s.statusCategory.key = 'done', 'done', 'queue'))), 'confidence', IF(OR(s.statusCategory.key = 'new', s.statusCategory.key = 'done'), 'high', 'medium'), 'reason', 'Derived from Jira statusCategory.key.'))"
        }
      },
