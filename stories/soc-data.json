        "method": "put",
        "headers": {
          "x-user-email": "<<RESOURCE.soc_tines_api.user_email>>",
          "x-user-token": "<<CREDENTIAL.tines_api_token>>"
        },
        "payload": {
          "value": "=OBJECT('mode', 'inline', 'project_key', sync_entry.project_key, 'last_synced_at', NOW(), 'total', normalize_to_ticketrow.total_fetched, 'tickets', normalize_to_ticketrow.accumulated)",
          "value_type": "json"
        }
      },
      "reporting": { "time_saved_value": 0, "time_saved_unit": "minutes" },
      "monitoring": { "monitor_all_events": false, "monitor_failures": false, "monitor_no_events_emitted": null },
