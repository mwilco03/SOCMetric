    {
      "type": "Agents::HTTPRequestAgent",
      "name": "Mark sync running",
      "disabled": false,
      "description": "Updates soc_settings.last_sync_status = running.",
      "guid": "a000006000000000000000000000ht01",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "url": "=CONCAT('https://', RESOURCE.soc_tines_api.domain, '/api/v1/global_resources/', RESOURCE.soc_tines_api.resource_ids.soc_settings)",
        "content_type": "json",
        "method": "put",
        "headers": {
          "x-user-email": "<<RESOURCE.soc_tines_api.user_email>>",
          "x-user-token": "<<CREDENTIAL.tines_api_token>>"
        },
        "payload": {
          "value": "=MERGE(RESOURCE.soc_settings, OBJECT('last_sync_status', 'running', 'last_sync_error', null))",
          "value_type": "json"
        }
      },
      "reporting": { "time_saved_value": 0, "time_saved_unit": "minutes" },
      "monitoring": { "monitor_all_events": false, "monitor_failures": false, "monitor_no_events_emitted": null },
      "template": { "created_from_template_guid": null, "created_from_template_version": null, "template_tags": [] },
      "width": null
    },
    {
      "type": "Agents::EventTransformationAgent",
      "name": "Build initial paging state",
      "disabled": false,
      "description": null,
      "guid": "a000007000000000000000000000et01",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "jql": "=CONCAT('project = \"', sync_entry.project_key, '\" AND created >= \"', sync_entry.start_date, '\" ORDER BY created ASC')",
          "nextPageToken": null,
          "accumulated": [],
          "page_num": 0
        }
      },
      "reporting": { "time_saved_value": 0, "time_saved_unit": "minutes" },
      "monitoring": { "monitor_all_events": false, "monitor_failures": false, "monitor_no_events_emitted": null },
      "template": { "created_from_template_guid": null, "created_from_template_version": null, "template_tags": [] },
      "width": null
    },
    {
      "type": "Agents::HTTPRequestAgent",
      "name": "Jira search page",
      "disabled": false,
      "description": "One page of the sync. expand=changelog included so the backfill happens in a single pass.",
      "guid": "a000008000000000000000000000ht02",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "url": "=CONCAT('https://', sync_entry.domain, '/rest/api/3/search/jql')",
        "method": "post",
        "content_type": "json",
        "basic_auth": [
          "<<CREDENTIAL.jira_basic_auth.email>>",
          "<<CREDENTIAL.jira_basic_auth.api_token>>"
        ],
        "headers": { "Accept": "application/json" },
        "payload": {
          "jql": "<<build_initial_paging_state.jql>>",
          "nextPageToken": "<<build_initial_paging_state.nextPageToken>>",
          "maxResults": "<<sync_entry.page_size>>",
          "fields": [
            "summary", "status", "issuetype", "priority", "assignee", "reporter",
            "labels", "components", "created", "updated", "resolutiondate"
          ],
          "expand": "changelog"
        }
      },
      "reporting": { "time_saved_value": 0, "time_saved_unit": "minutes" },
      "monitoring": { "monitor_all_events": false, "monitor_failures": false, "monitor_no_events_emitted": null },
      "template": { "created_from_template_guid": null, "created_from_template_version": null, "template_tags": [] },
      "width": null
    },
    {
      "type": "Agents::EventTransformationAgent",
      "name": "Normalize to TicketRow",
      "disabled": false,
      "description": "Flattens Jira issues to 17-field TicketRow shape; keeps only status changelog entries.",
      "guid": "a000009000000000000000000000et02",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "tickets_page": "=MAP(jira_search_page.body.issues, i, OBJECT('id', i.id, 'key', i.key, 'project_key', sync_entry.project_key, 'summary', i.fields.summary, 'status_name', i.fields.status.name, 'status_category_key', i.fields.status.statusCategory.key, 'issue_type', i.fields.issuetype.name, 'priority', IF(i.fields.priority, i.fields.priority.name, null), 'assignee', IF(i.fields.assignee, i.fields.assignee.displayName, null), 'reporter', IF(i.fields.reporter, i.fields.reporter.displayName, null), 'labels', i.fields.labels, 'components', MAP(i.fields.components, c, c.name), 'created_at', i.fields.created, 'updated_at', i.fields.updated, 'resolved_at', i.fields.resolutiondate, 'changelog_json', JSON_STRINGIFY(FILTER(MAP(i.changelog.histories, h, OBJECT('id', h.id, 'created', h.created, 'items', FILTER(h.items, it, it.field = 'status'))), hh, LENGTH(hh.items) > 0)), 'fetched_at', NOW()))",
          "accumulated": "=CONCAT(build_initial_paging_state.accumulated, normalize_to_ticketrow.tickets_page)",
          "nextPageToken": "<<jira_search_page.body.nextPageToken>>",
          "isLast": "<<jira_search_page.body.isLast>>",
          "total_fetched": "=LENGTH(CONCAT(build_initial_paging_state.accumulated, normalize_to_ticketrow.tickets_page))"
        }
      },
      "reporting": { "time_saved_value": 0, "time_saved_unit": "minutes" },
      "monitoring": { "monitor_all_events": false, "monitor_failures": false, "monitor_no_events_emitted": null },
      "template": { "created_from_template_guid": null, "created_from_template_version": null, "template_tags": [] },
      "width": null
    },
    {
      "type": "Agents::TriggerAgent",
      "name": "More pages?",
      "disabled": false,
      "description": "Loop guard: continue paging when not last and under cap.",
      "guid": "a00000a000000000000000000000gt02",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "rules": [ { "type": "formula", "value": "true", "path": "=AND(normalize_to_ticketrow.isLast = false, normalize_to_ticketrow.total_fetched < sync_entry.max_issues)" } ]
      },
      "reporting": { "time_saved_value": 0, "time_saved_unit": "minutes" },
      "monitoring": { "monitor_all_events": false, "monitor_failures": false, "monitor_no_events_emitted": null },
      "template": { "created_from_template_guid": null, "created_from_template_version": null, "template_tags": [] },
      "width": null
    },
    {
      "type": "Agents::TriggerAgent",
      "name": "Done paging",
      "disabled": false,
      "description": "Paging complete; proceed to write + compute.",
      "guid": "a00000b000000000000000000000gt03",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "rules": [ { "type": "formula", "value": "true", "path": "=OR(normalize_to_ticketrow.isLast = true, normalize_to_ticketrow.total_fetched >= sync_entry.max_issues)" } ]
      },
      "reporting": { "time_saved_value": 0, "time_saved_unit": "minutes" },
      "monitoring": { "monitor_all_events": false, "monitor_failures": false, "monitor_no_events_emitted": null },
      "template": { "created_from_template_guid": null, "created_from_template_version": null, "template_tags": [] },
      "width": null
    },
    {
      "type": "Agents::HTTPRequestAgent",
      "name": "Write tickets cache",
      "disabled": false,
      "description": "Updates the soc_tickets_cache Resource via the Tines API.",
      "guid": "a00000c000000000000000000000ht03",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "url": "=CONCAT('https://', RESOURCE.soc_tines_api.domain, '/api/v1/global_resources/', RESOURCE.soc_tines_api.resource_ids.soc_tickets_cache)",
