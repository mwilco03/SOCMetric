          "slice": "=OBJECT('queue_depth', LENGTH(FILTER(webhook.body.tickets, t, LOOKUP(webhook.body.status_map, CONCAT(t.project_key, ':', t.status_name), 'queue') = 'queue')), 'active_incident_count', LENGTH(FILTER(webhook.body.tickets, t, LOOKUP(webhook.body.status_map, CONCAT(t.project_key, ':', t.status_name), 'queue') = 'active')), 'ttft_p85_hours', PERCENTILE(FILTER(MAP(webhook.body.tickets, t, TTFT_HOURS(t)), v, v != null), 85), 'ttft_p50_hours', PERCENTILE(FILTER(MAP(webhook.body.tickets, t, TTFT_HOURS(t)), v, v != null), 50), 'ttft_p95_hours', PERCENTILE(FILTER(MAP(webhook.body.tickets, t, TTFT_HOURS(t)), v, v != null), 95), 'net_velocity_7d', (LENGTH(FILTER(webhook.body.tickets, t, AND(t.resolved_at != null, DATE_DIFF(NOW(), t.resolved_at, 'days') <= 7))) - LENGTH(FILTER(webhook.body.tickets, t, DATE_DIFF(NOW(), t.created_at, 'days') <= 7))) / 7)",
