        "payload": {
          "op": "<<webhook.body.op>>",
          "current": "<<RESOURCE.soc_label_config>>",
          "next_value": "=IF(webhook.body.op = 'set', MERGE(RESOURCE.soc_label_config, OBJECT(webhook.body.key, webhook.body.value)), IF(webhook.body.op = 'delete', OMIT(RESOURCE.soc_label_config, webhook.body.key), IF(webhook.body.op = 'bulk_set', MERGE(RESOURCE.soc_label_config, webhook.body.mappings), RESOURCE.soc_label_config)))"
        }
      },
