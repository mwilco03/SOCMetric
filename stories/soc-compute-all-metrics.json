      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "tickets": "=IF(RESOURCE.soc_tickets_cache.mode = 'inline', RESOURCE.soc_tickets_cache.tickets, FLATTEN(MAP(RANGE(1, RESOURCE.soc_tickets_cache.shards + 1), i, RESOURCE_BY_NAME(CONCAT('soc_tickets_cache_shard_', PAD_LEFT(i, 3, '0'))).tickets)))",
