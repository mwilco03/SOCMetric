  "name": "SOC: Jira sync",
  "description": "Scheduled: pages Jira /search/jql, normalizes issues to TicketRow, writes soc_tickets_cache, triggers compute fan-out.",
  "guid": "ae0369acde529dfd77c9ae2987d0688e",
  "slug": "soc_jira_sync",
  "agents": [
