{
  "schema_version": 28,
  "standard_lib_version": 90,
  "action_runtime_version": 74,
  "name": "SOC: Jira sync",
  "description": "Scheduled sync. Pages /rest/api/3/search/jql with expand=changelog, flattens each issue to TicketRow, writes soc_tickets_cache, then fires soc-compute-all-metrics. Attach a cron schedule on the first action.",
  "guid": "ae0369acde529dfd77c9ae2987d0688e",
  "slug": "soc_jira_sync",
  "agents": [
    {
      "type": "Agents::EventTransformationAgent",
      "name": "Scheduled start",
      "disabled": false,
      "description": "Entry action. Attach a schedule (cron) on this action in the Tines UI.",
      "guid": "ff39e4bf1c3f4b9f8b7162c9461b6001",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "project_key": "<<RESOURCE.soc_settings.project_key>>",
          "domain": "<<RESOURCE.soc_settings.jira_domain>>",
          "date_range_days": "<<RESOURCE.soc_settings.date_range_days>>",
          "max_issues": "<<RESOURCE.soc_settings.max_issues_per_sync>>",
          "page_size": "<<RESOURCE.soc_settings.page_size>>",
          "start_date": "=DATE_FORMAT(DATE_SUBTRACT(NOW(), RESOURCE.soc_settings.date_range_days, 'days'), 'yyyy-MM-dd')",
          "now": "=NOW()"
        }
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
      },
      "monitoring": {
        "monitor_all_events": false,
        "monitor_failures": false,
        "monitor_no_events_emitted": null
      },
      "template": {
        "created_from_template_guid": null,
        "created_from_template_version": null,
        "template_tags": []
      },
      "width": null
    },
    {
      "type": "Agents::TriggerAgent",
      "name": "Gate: project_key set",
      "disabled": false,
      "description": "Exits without work if no project has been configured.",
      "guid": "571416f9d7dabbfefcf489d2b95a58b7",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "rules": [
          {
            "type": "formula",
            "value": "true",
            "path": "=LENGTH(project_key) > 0"
          }
        ]
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
      },
      "monitoring": {
        "monitor_all_events": false,
        "monitor_failures": false,
        "monitor_no_events_emitted": null
      },
      "template": {
        "created_from_template_guid": null,
        "created_from_template_version": null,
        "template_tags": []
      },
      "width": null
    },
    {
      "type": "Agents::HTTPRequestAgent",
      "name": "Mark sync running",
      "disabled": false,
      "description": "Updates the soc_settings Resource via the Tines API.",
      "guid": "458220a207800b3a7ad257fa72a4d6ce",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "url": "=CONCAT('https://', RESOURCE.soc_tines_api.domain, '/api/v1/global_resources/', RESOURCE.soc_tines_api.resource_ids.soc_settings)",
        "content_type": "json",
        "method": "put",
        "headers": {
          "x-user-email": "<<RESOURCE.soc_tines_api.user_email>>",
          "x-user-token": "<<CREDENTIAL.tines_api_token>>"
        },
        "payload": {
          "value": "=MERGE(RESOURCE.soc_settings, OBJECT('last_sync_status', 'running', 'last_sync_error', null))",
          "value_type": "json"
        }
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
      },
      "monitoring": {
        "monitor_all_events": false,
        "monitor_failures": false,
        "monitor_no_events_emitted": null
      },
      "template": {
        "created_from_template_guid": null,
        "created_from_template_version": null,
        "template_tags": []
      },
      "width": null
    },
    {
      "type": "Agents::EventTransformationAgent",
      "name": "Build initial paging state",
      "disabled": false,
      "description": null,
      "guid": "d86cf3d397722ecebe5b762fc683b002",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "jql": "=CONCAT('project = \"', scheduled_start.project_key, '\" AND created >= \"', scheduled_start.start_date, '\" ORDER BY created ASC')",
          "nextPageToken": null,
          "accumulated": [],
          "page_num": 0
        }
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
      },
      "monitoring": {
        "monitor_all_events": false,
        "monitor_failures": false,
        "monitor_no_events_emitted": null
      },
      "template": {
        "created_from_template_guid": null,
        "created_from_template_version": null,
        "template_tags": []
      },
      "width": null
    },
    {
      "type": "Agents::HTTPRequestAgent",
      "name": "Jira search page",
      "disabled": false,
      "description": "One page of the sync. expand=changelog included so the backfill happens in a single pass.",
      "guid": "270a7c084fb699d914ec647e2ef07ac3",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "url": "=CONCAT('https://', scheduled_start.domain, '/rest/api/3/search/jql')",
        "method": "post",
        "content_type": "json",
        "basic_auth": [
          "<<CREDENTIAL.jira_basic_auth.email>>",
          "<<CREDENTIAL.jira_basic_auth.api_token>>"
        ],
        "headers": {
          "Accept": "application/json"
        },
        "payload": {
          "jql": "<<build_initial_paging_state.jql>>",
          "nextPageToken": "<<build_initial_paging_state.nextPageToken>>",
          "maxResults": "<<scheduled_start.page_size>>",
          "fields": [
            "summary",
            "status",
            "issuetype",
            "priority",
            "assignee",
            "reporter",
            "labels",
            "components",
            "created",
            "updated",
            "resolutiondate"
          ],
          "expand": "changelog"
        }
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
      },
      "monitoring": {
        "monitor_all_events": false,
        "monitor_failures": false,
        "monitor_no_events_emitted": null
      },
      "template": {
        "created_from_template_guid": null,
        "created_from_template_version": null,
        "template_tags": []
      },
      "width": null
    },
    {
      "type": "Agents::EventTransformationAgent",
      "name": "Normalize to TicketRow",
      "disabled": false,
      "description": "Flattens Jira issues to 17-field TicketRow shape; keeps only status changelog entries.",
      "guid": "0b168b0ecf7bb822bfe6add600164214",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "tickets_page": "=MAP(jira_search_page.body.issues, i, OBJECT('id', i.id, 'key', i.key, 'project_key', scheduled_start.project_key, 'summary', i.fields.summary, 'status_name', i.fields.status.name, 'status_category_key', i.fields.status.statusCategory.key, 'issue_type', i.fields.issuetype.name, 'priority', IF(i.fields.priority, i.fields.priority.name, null), 'assignee', IF(i.fields.assignee, i.fields.assignee.displayName, null), 'reporter', IF(i.fields.reporter, i.fields.reporter.displayName, null), 'labels', i.fields.labels, 'components', MAP(i.fields.components, c, c.name), 'created_at', i.fields.created, 'updated_at', i.fields.updated, 'resolved_at', i.fields.resolutiondate, 'changelog_json', JSON_STRINGIFY(FILTER(MAP(i.changelog.histories, h, OBJECT('id', h.id, 'created', h.created, 'items', FILTER(h.items, it, it.field = 'status'))), hh, LENGTH(hh.items) > 0)), 'fetched_at', NOW()))",
          "accumulated": "=CONCAT(build_initial_paging_state.accumulated, normalize_to_ticketrow.tickets_page)",
          "nextPageToken": "<<jira_search_page.body.nextPageToken>>",
          "isLast": "<<jira_search_page.body.isLast>>",
          "total_fetched": "=LENGTH(CONCAT(build_initial_paging_state.accumulated, normalize_to_ticketrow.tickets_page))"
        }
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
      },
      "monitoring": {
        "monitor_all_events": false,
        "monitor_failures": false,
        "monitor_no_events_emitted": null
      },
      "template": {
        "created_from_template_guid": null,
        "created_from_template_version": null,
        "template_tags": []
      },
      "width": null
    },
    {
      "type": "Agents::TriggerAgent",
      "name": "More pages?",
      "disabled": false,
      "description": "Loop guard: continue paging when not last and under cap.",
      "guid": "12faa970d1ee15bfab1b7adebf6ee4d1",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "rules": [
          {
            "type": "formula",
            "value": "true",
            "path": "=AND(normalize_to_ticketrow.isLast = false, normalize_to_ticketrow.total_fetched < scheduled_start.max_issues)"
          }
        ]
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
      },
      "monitoring": {
        "monitor_all_events": false,
        "monitor_failures": false,
        "monitor_no_events_emitted": null
      },
      "template": {
        "created_from_template_guid": null,
        "created_from_template_version": null,
        "template_tags": []
      },
      "width": null
    },
    {
      "type": "Agents::TriggerAgent",
      "name": "Done paging",
      "disabled": false,
      "description": "Paging complete; proceed to write + compute.",
      "guid": "266888ebc5fd0bfa7c6e9d82ef261856",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "rules": [
          {
            "type": "formula",
            "value": "true",
            "path": "=OR(normalize_to_ticketrow.isLast = true, normalize_to_ticketrow.total_fetched >= scheduled_start.max_issues)"
          }
        ]
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
      },
      "monitoring": {
        "monitor_all_events": false,
        "monitor_failures": false,
        "monitor_no_events_emitted": null
      },
      "template": {
        "created_from_template_guid": null,
        "created_from_template_version": null,
        "template_tags": []
      },
      "width": null
    },
    {
      "type": "Agents::HTTPRequestAgent",
      "name": "Write tickets cache",
      "disabled": false,
      "description": "Updates the soc_tickets_cache Resource via the Tines API.",
      "guid": "0852ce975be8ad11192617b39bb7cb6c",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "url": "=CONCAT('https://', RESOURCE.soc_tines_api.domain, '/api/v1/global_resources/', RESOURCE.soc_tines_api.resource_ids.soc_tickets_cache)",
        "content_type": "json",
        "method": "put",
        "headers": {
          "x-user-email": "<<RESOURCE.soc_tines_api.user_email>>",
          "x-user-token": "<<CREDENTIAL.tines_api_token>>"
        },
        "payload": {
          "value": "=OBJECT('mode', 'inline', 'project_key', scheduled_start.project_key, 'last_synced_at', NOW(), 'total', normalize_to_ticketrow.total_fetched, 'tickets', normalize_to_ticketrow.accumulated)",
          "value_type": "json"
        }
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
      },
      "monitoring": {
        "monitor_all_events": false,
        "monitor_failures": false,
        "monitor_no_events_emitted": null
      },
      "template": {
        "created_from_template_guid": null,
        "created_from_template_version": null,
        "template_tags": []
      },
      "width": null
    },
    {
      "type": "Agents::HTTPRequestAgent",
      "name": "Mark sync ok",
      "disabled": false,
      "description": "Updates the soc_settings Resource via the Tines API.",
      "guid": "f1c1abb66fcc13d1f50c9961394834d7",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "url": "=CONCAT('https://', RESOURCE.soc_tines_api.domain, '/api/v1/global_resources/', RESOURCE.soc_tines_api.resource_ids.soc_settings)",
        "content_type": "json",
        "method": "put",
        "headers": {
          "x-user-email": "<<RESOURCE.soc_tines_api.user_email>>",
          "x-user-token": "<<CREDENTIAL.tines_api_token>>"
        },
        "payload": {
          "value": "=MERGE(RESOURCE.soc_settings, OBJECT('last_sync_status', 'ok', 'last_sync_error', null, 'last_sync_completed_at', NOW(), 'first_sync_completed_at', COALESCE(RESOURCE.soc_settings.first_sync_completed_at, NOW())))",
          "value_type": "json"
        }
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
      },
      "monitoring": {
