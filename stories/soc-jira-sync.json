    {
      "type": "Agents::HTTPRequestAgent",
      "name": "Jira search page",
      "disabled": false,
      "description": "One page of the two-pass sync, expand=changelog included.",
      "guid": "270a7c084fb699d914ec647e2ef07ac3",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "url": "https://<<domain>>/rest/api/3/search/jql",
        "method": "post",
        "content_type": "application_json",
        "basic_auth": [
          "<<CREDENTIAL.jira_basic_auth.email>>",
          "<<CREDENTIAL.jira_basic_auth.api_token>>"
        ],
        "headers": {
          "Accept": "application/json"
        },
        "payload": {
          "jql": "<<jql>>",
          "nextPageToken": "<<nextPageToken>>",
          "maxResults": "<<page_size>>",
          "fields": [
            "summary",
            "status",
            "issuetype",
            "priority",
            "assignee",
            "reporter",
            "labels",
            "components",
            "created",
            "updated",
            "resolutiondate"
          ],
          "expand": "changelog"
        }
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
      },
      "monitoring": {
        "monitor_all_events": false,
        "monitor_failures": false,
        "monitor_no_events_emitted": null
      },
      "template": {
        "created_from_template_guid": null,
        "created_from_template_version": null,
        "template_tags": []
      },
      "width": null,
      "position": {
        "x": 0,
        "y": 600
      },
      "schedule": null
    },
    {
      "type": "Agents::EventTransformationAgent",
      "name": "Normalize to TicketRow",
      "disabled": false,
      "description": "Flattens Jira issues to 17-field TicketRow; keeps only status changelog entries.",
      "guid": "0b168b0ecf7bb822bfe6add600164214",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "mode": "message_only",
        "payload": {
          "tickets_page": "<<MAP_LAMBDA(issues, i, {\"id\": i.id, \"key\": i.key, \"project_key\": project_key, \"summary\": i.fields.summary, \"status_name\": i.fields.status.name, \"status_category_key\": i.fields.status.statusCategory.key, \"issue_type\": i.fields.issuetype.name, \"priority\": i.fields.priority ? i.fields.priority.name : null, \"assignee\": i.fields.assignee ? i.fields.assignee.displayName : null, \"reporter\": i.fields.reporter ? i.fields.reporter.displayName : null, \"labels\": i.fields.labels, \"components\": MAP_LAMBDA(i.fields.components, c, c.name), \"created_at\": i.fields.created, \"updated_at\": i.fields.updated, \"resolved_at\": i.fields.resolutiondate, \"changelog_json\": JSON_STRINGIFY(FILTER(MAP_LAMBDA(i.changelog.histories, h, {\"id\": h.id, \"created\": h.created, \"items\": FILTER(h.items, it, it.field == 'status')}), hh, COUNT(hh.items) > 0)), \"fetched_at\": NOW()})>>",
          "accumulated": "<<CONCAT(accumulated, tickets_page)>>",
          "nextPageToken": "<<.nextPageToken>>",
          "isLast": "<<.isLast>>",
          "total_fetched": "<<COUNT(CONCAT(accumulated, tickets_page))>>"
        }
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
      },
      "monitoring": {
        "monitor_all_events": false,
        "monitor_failures": false,
        "monitor_no_events_emitted": null
      },
