    {
      "type": "Agents::EventTransformationAgent",
      "name": "Build initial JQL",
      "disabled": false,
      "description": null,
      "guid": "ce5ff046e8b0bc050a23745e18ce7ca9",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "mode": "message_only",
        "payload": {
          "jql": "project = \"<<project_key>>\" AND created >= \"<<DATE_SUBTRACT(NOW(), date_range_days, 'days') | date_format('yyyy-MM-dd')>>\" ORDER BY created ASC",
          "nextPageToken": null,
          "accumulated": [],
          "page_num": 0
        }
      },
