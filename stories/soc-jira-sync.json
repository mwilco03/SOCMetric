    {
      "type": "Agents::EventTransformationAgent",
      "name": "Loop or finish",
      "disabled": false,
      "description": null,
      "guid": "4a52ef0e3560cd744dba0537c7834fa3",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "mode": "message_only",
        "payload": {
          "continue": "<<AND(isLast == false, total_fetched < max_issues)>>",
          "done": "<<OR(isLast == true, total_fetched >= max_issues)>>"
        }
      },
