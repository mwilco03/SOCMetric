    },
    {
      "type": "Agents::TriggerAgent",
      "name": "Rate-limit delay",
      "disabled": false,
      "description": "200ms-ish delay + loop gate when more pages remain.",
      "guid": "483112ecf177d24a18f6c0f2ab816f40",
      "origin_story_identifier": "socmetric:tines-webapp:v1",
      "options": {
        "rules": [
